# Plex server on your LAN
PLEX_SERVER_URL=http://192.168.1.x:32400

# TMDB — augments indexed data with composer info (optional)
# Get Read Access Token at: https://www.themoviedb.org/settings/api
# If blank, composer data is skipped — no other impact.
TMDB_READ_ACCESS_TOKEN=
PLEX_APP_NAME=PlexSearch
# Generate once: python -c "import uuid; print(uuid.uuid4())"
PLEX_CLIENT_ID=

# ── AI Providers ──────────────────────────────────────────────────────────────
# LLM_PROVIDER:   ollama (default) | together | openai | anthropic
# EMBED_PROVIDER: ollama (default) | openai   | together
#
# WARNING: changing EMBED_PROVIDER invalidates existing vectors.
# After switching: docker compose down -v && docker compose up  (wipes chroma volume)
LLM_PROVIDER=ollama
EMBED_PROVIDER=ollama

# Optional model overrides (leave blank for provider defaults)
# Defaults: ollama→qwen2.5:7b, together→Qwen2.5-7B-Instruct-Turbo,
#           openai→gpt-4o-mini, anthropic→claude-haiku-4-5-20251001
LLM_MODEL=
# Defaults: ollama→nomic-embed-text, openai→text-embedding-3-small (768-dim),
#           together→m2-bert-80M-8k-retrieval (768-dim)
EMBED_MODEL=

# Cloud API keys (only required for respective provider)
TOGETHER_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Optional API base overrides — point at any local OpenAI-compatible server
# Example (vLLM in docker-compose):
#   LLM_PROVIDER=openai
#   LLM_API_BASE=http://vllm:8000
#   LLM_MODEL=openai/mistral-7b
# Example (LocalAI):
#   LLM_PROVIDER=openai
#   LLM_API_BASE=http://localai:8080
#   LLM_MODEL=openai/ggml-gpt4all-j
LLM_API_BASE=
EMBED_API_BASE=

# ── Ollama (local — only needed when LLM_PROVIDER or EMBED_PROVIDER = ollama) ─
# LLM: qwen2.5:7b fits 6GB VRAM; qwen2.5:14b recommended on RTX 3060 (12GB)
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_EMBED_MODEL=nomic-embed-text
# Keep models in VRAM permanently (-1). Use 5m to unload after idle (saves VRAM on shared GPUs).
OLLAMA_KEEP_ALIVE=-1
# Parallel embed slots — each nomic-embed-text slot ~274MB
OLLAMA_NUM_PARALLEL=4
# Max models loaded simultaneously (LLM + embed = 2)
OLLAMA_MAX_LOADED_MODELS=2

# ── Session & CORS ────────────────────────────────────────────────────────────
# Generate: openssl rand -hex 32
SESSION_SECRET=
# Set to true when behind HTTPS (Cloudflare Tunnel, reverse proxy, etc.)
# Adds Secure flag to session cookie. Leave false for plain HTTP LAN access.
SESSION_HTTPS_ONLY=false
# Frontend URL (no trailing slash)
# LAN:              http://192.168.1.x
# Cloudflare Tunnel: https://plexsearch.yourdomain.com
FRONTEND_URL=http://localhost
# Must match FRONTEND_URL origin. Add http://localhost:5173 for Vite dev server.
BACKEND_CORS_ORIGINS=http://localhost,http://localhost:5173

# ChromaDB persistence path inside backend container
CHROMA_PERSIST_DIR=/data/chroma
